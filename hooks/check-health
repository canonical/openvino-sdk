#!/bin/bash
set -e

# Verify native library is present
ldconfig -p | grep -q libopenvino || { workshopctl set-health error "libopenvino not found"; exit 1; }

# Verify Python bindings are discoverable (the .pth registration worked)
python3 -c "import openvino; import openvino_genai" \
  || { workshopctl set-health error "Python bindings not discoverable"; exit 1; }

workshopctl set-health okay
