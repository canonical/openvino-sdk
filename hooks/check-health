# Verify native library is present
if ! ldconfig -p | grep libopenvino >/dev/null; then
	workshopctl set-health --code="openvino-lib-missing" error "libopenvino not found"
	exit 0
fi

# Verify Python bindings are discoverable (the .pth registration worked)
if ! python3 -c "import openvino; import openvino_genai"; then
	workshopctl set-health --code="openvino-python-missing" error "Python bindings not discoverable"
	exit 0
fi

workshopctl set-health okay
